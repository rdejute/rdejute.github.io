# Local env for `supabase functions serve --env-file supabase/functions/.env`.
# Copy to supabase/functions/.env (gitignored) and fill in from the Supabase
# dashboard's Connect dialog. On deployed Edge Functions these are injected
# automatically, so you do NOT set them there.
#
# NEVER commit the secret key. It bypasses RLS (used by ctx.supabaseAdmin).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# notify-contact function (Resend email on new contact message).
# NEVER commit real values — set these via `supabase secrets set ...`.
RESEND_API_KEY=re_your_new_rotated_key
CONTACT_NOTIFY_TO=you@example.com
CONTACT_NOTIFY_FROM=onboarding@resend.dev
CONTACT_WEBHOOK_SECRET=a-long-random-string
